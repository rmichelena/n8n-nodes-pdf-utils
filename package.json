{
  "name": "n8n-nodes-pdf-utils",
  "version": "1.0.0",
  "description": "Custom n8n node for PDF inspection and splitting using pure npm packages",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "pdf",
    "pdf-utils"
  ],
  "license": "MIT",
  "homepage": "",
  "author": {
    "name": "Roberto Michelena",
    "email": "roberto@infinitek.pe"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/n8n-nodes-pdf-utils.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials package.json",
    "verify": "node verify.js"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/PdfUtils/PdfUtils.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.0.0",
    "prettier": "^2.7.1",
    "typescript": "^4.9.0"
  },
  "dependencies": {
    "pdfjs-dist": "^3.11.174",
    "pdf-lib": "^1.17.1"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
